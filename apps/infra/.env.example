# ALL-Flow infra environment variables (template)
# Copy to .env.dev or .env.prod and fill real values.
# IMPORTANT: never commit .env.dev / .env.prod (already in .gitignore).

# ---- Compose ----
COMPOSE_PROJECT_NAME=allflow
NODE_ENV=development
IMAGE_TAG=local
LOG_LEVEL=debug

# ---- Postgres ----
POSTGRES_USER=allflow
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=allflow
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379
# Leave empty for no auth in dev; set strong value for prod.
REDIS_PASSWORD=

# ---- Backend ----
BACKEND_PORT=8080
# Generate via: openssl rand -hex 32
JWT_SECRET=replace_me_with_32_byte_random_hex
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Frontend ----
FRONTEND_PORT=3000
NEXTAUTH_URL=http://localhost:3000
BACKEND_URL=http://backend:8080/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_USE_MOCK=false

# ---- Image refs (prod only) ----
BACKEND_IMAGE=allflow-backend:latest
FRONTEND_IMAGE=allflow-frontend:latest

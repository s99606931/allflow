# API
NEXT_PUBLIC_USE_MOCK=true
NEXT_PUBLIC_API_BASE_URL=https://api.allflow.omelet.ai/v1

# Realtime — 'mock' | 'sse' | 'ws'
NEXT_PUBLIC_REALTIME_MODE=mock
NEXT_PUBLIC_WS_URL=wss://api.allflow.omelet.ai/v1/realtime/ws
NEXT_PUBLIC_SSE_URL=https://api.allflow.omelet.ai/v1/realtime/sse

# Auth (next-auth v5)
AUTH_SECRET=                    # 프로덕션 필수 (openssl rand -hex 32)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=

// ALL-Flow backend Prisma schema
// T-101: Phase 1 Foundation — User/Project/Task/Issue/Report/Notification/Comment 7 entities.
// Mirrors all-flow-frontend openapi.yaml schemas.
//
// Conventions:
//  - Identifiers are string CUIDs (frontend uses opaque string IDs).
//  - Soft delete via deletedAt (nullable). Cascade rules defined per relation.
//  - Status enums are mirrored from openapi.yaml (StatusKey/IssueStatus/IssueSev/IssuePrio).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// =====================================================================
// Enums (mirror openapi.yaml)
// =====================================================================

enum StatusKey {
  todo
  doing
  review
  done
  blocked
}

enum Priority {
  high
  med
  low
}

enum IssueSev {
  critical
  high
  med
  low
}

enum IssuePrio {
  P0
  P1
  P2
  P3
}

enum IssueStatus {
  open
  in_progress  @map("in-progress")
  in_review    @map("in-review")
  resolved
}

enum ReportKind {
  weekly
  monthly
}

enum NotificationKind {
  mention
  sla
  ai
  system
  comment
}

enum MemberRole {
  owner
  admin
  member
}

enum CommentTargetKind {
  task
  issue
}

enum TaskKind {
  task
  milestone
  summary
}

enum DependencyType {
  FS
  SS
  FF
  SF
}

// =====================================================================
// User / Project / Membership
// =====================================================================

model User {
  id        String   @id @default(cuid())
  name      String
  role      String
  dept      String
  initials  String
  color     String
  email     String?  @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships       ProjectMember[]
  authoredTasks     Task[]            @relation("TaskCreatedBy")
  assignedTasks     Task[]            @relation("TaskAssignee")
  reportedIssues    Issue[]           @relation("IssueReporter")
  assignedIssues    Issue[]           @relation("IssueAssignee")
  comments          Comment[]
  notifications     Notification[]
  reports           Report[]          @relation("ReportAuthor")
  messages          Message[]         @relation("MessageAuthor")
  auditLogs         AuditLog[]        @relation("AuditLogActor")
  leaveRequests     LeaveRequest[]    @relation("LeaveRequester")
  approvedLeaves    LeaveRequest[]    @relation("LeaveApprover")
  notionConnections NotionConnection[] @relation("NotionConnections")

  @@index([deletedAt])
  @@map("users")
}

model Project {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  color     String
  progress  Int       @default(0)
  status    StatusKey @default(doing)
  due       DateTime? @db.Date

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  members ProjectMember[]
  tasks   Task[]
  issues  Issue[]

  @@index([status])
  @@index([deletedAt])
  @@map("projects")
}

model ProjectMember {
  projectId String     @map("project_id")
  userId    String     @map("user_id")
  role      MemberRole @default(member)
  joinedAt  DateTime   @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

// =====================================================================
// Task / Issue / Comment
// =====================================================================

model Task {
  id          String                  @id @default(cuid())
  title       String
  status      StatusKey               @default(todo)
  due         String?                 // OpenAPI Task.due is free-form string ("오늘", "내일", "5/2")
  priority    Priority                @default(med)
  tags        String[]                @default([])
  embedding   Unsupported("vector(1536)")?  @map("embedding") // OpenAI text-embedding-3-small

  // Gantt fields (Phase 1 — gantt-chart-2026-04-30)
  startDate    DateTime? @db.Date @map("start_date")
  endDate      DateTime? @db.Date @map("end_date")
  parentTaskId String?            @map("parent_task_id")
  kind         TaskKind  @default(task)
  progress     Int       @default(0)

  projectId   String    @map("project_id")
  assigneeId  String?   @map("assignee_id")
  createdById String?   @map("created_by_id")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy  User?     @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  comments   Comment[] @relation("TaskComments")

  parent       Task?  @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children     Task[] @relation("TaskHierarchy")
  predecessors TaskDependency[] @relation("Successor")
  successors   TaskDependency[] @relation("Predecessor")

  @@index([projectId, status])
  @@index([assigneeId])
  @@index([deletedAt])
  @@index([startDate, endDate])
  @@index([parentTaskId])
  @@map("tasks")
}

model TaskDependency {
  id            String         @id @default(cuid())
  predecessorId String         @map("predecessor_id")
  successorId   String         @map("successor_id")
  type          DependencyType @default(FS)
  lagDays       Int            @default(0) @map("lag_days")

  createdAt DateTime @default(now()) @map("created_at")

  predecessor Task @relation("Predecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor   Task @relation("Successor", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
  @@index([predecessorId])
  @@index([successorId])
  @@map("task_dependencies")
}

model Issue {
  id          String      @id @default(cuid())
  title       String
  projColor   String      @map("proj_color")
  embedding   Unsupported("vector(1536)")?  @map("embedding") // OpenAI text-embedding-3-small
  sev         IssueSev
  prio        IssuePrio
  status      IssueStatus @default(open)
  tags        String[]    @default([])
  sla         String      // human-readable SLA window e.g. "12h", "3d"
  slaPct      Int         @default(0) @map("sla_pct")
  linked      Int         @default(0)
  resolved    Boolean     @default(false)

  projectId   String      @map("project_id")
  assigneeId  String?     @map("assignee_id")
  reporterId  String?     @map("reporter_id")

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee  User?     @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter  User?     @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  comments  Comment[] @relation("IssueComments")

  @@index([projectId, status])
  @@index([prio])
  @@index([assigneeId])
  @@index([deletedAt])
  @@map("issues")
}

model Comment {
  id          String            @id @default(cuid())
  body        String
  targetKind  CommentTargetKind @map("target_kind")
  taskId      String?           @map("task_id")
  issueId     String?           @map("issue_id")
  authorId    String            @map("author_id")

  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")

  task    Task?  @relation("TaskComments", fields: [taskId], references: [id], onDelete: Cascade)
  issue   Issue? @relation("IssueComments", fields: [issueId], references: [id], onDelete: Cascade)
  author  User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([issueId])
  @@index([authorId])
  @@map("comments")
}

// =====================================================================
// Report / Notification
// =====================================================================

model Report {
  id           String     @id @default(cuid())
  kind         ReportKind
  periodStart  DateTime   @db.Date @map("period_start")
  periodEnd    DateTime   @db.Date @map("period_end")
  generatedAt  DateTime   @default(now()) @map("generated_at")
  tldr         String?
  authorId     String?    @map("author_id")

  // Structured payload (kpis / sections / citations) as JSONB; mirrors openapi.yaml Report.
  kpis         Json       @default("[]")
  sections     Json       @default("[]")

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  author User? @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([kind, periodStart])
  @@map("reports")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  kind      NotificationKind
  title     String
  body      String?
  actor     String?
  href      String?
  read      Boolean          @default(false)

  createdAt DateTime         @default(now()) @map("created_at")
  readAt    DateTime?        @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// =====================================================================
// LLM Connection (admin-managed AI provider registry)
// =====================================================================
//
// Allows admins to register multiple LLM endpoints (local: LMStudio/Ollama,
// commercial: OpenAI/Anthropic) and switch the active default at runtime
// without env-var redeploy. Adapter selection is `kind`-based; the request
// shape is always OpenAI-compatible /v1/chat/completions (LMStudio, Ollama,
// vLLM, OpenAI, Together, Groq, etc all expose this).
//
// Default seed: LMStudio @ http://192.168.0.104:1234 model gemma-4-e4b-it.
//
// Secrets policy: apiKey stored encrypted is out of scope for this cycle —
// kept as plaintext NULLABLE column. Local LLMs (the default) need no key.
// Commercial entries should be added via admin UI in trusted networks only.

enum LlmKind {
  lmstudio
  ollama
  openai
  anthropic
  custom_openai_compat  @map("custom-openai-compat")
}

model LlmConnection {
  id          String   @id @default(cuid())
  name        String   // display name, e.g. "LMStudio (local)"
  kind        LlmKind
  baseUrl     String   @map("base_url")  // e.g. http://192.168.0.104:1234
  model       String                      // e.g. gemma-4-e4b-it
  apiKey      String?  @map("api_key")    // null for local; required for commercial
  isActive    Boolean  @default(false) @map("is_active") // exactly one row should be true
  isDefault   Boolean  @default(false) @map("is_default") // seeded default (cannot be deleted)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt       @map("updated_at")

  @@index([isActive])
  @@map("llm_connections")
}

// =====================================================================
// Channel / Message (chat persistence)
// =====================================================================

enum ChannelKind {
  public
  private
  dm
}

model Channel {
  id        String      @id @default(cuid())
  name      String
  kind      ChannelKind @default(public)

  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  messages  Message[]

  @@index([kind])
  @@map("channels")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  channelId String   @map("channel_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author  User     @relation("MessageAuthor", fields: [authorId], references: [id])
  parent  Message? @relation("MessageThread", fields: [parentId], references: [id])
  replies Message[] @relation("MessageThread")

  @@index([channelId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("messages")
}

// =====================================================================
// AuditLog (admin audit trail)
// =====================================================================

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String   @map("actor_id")
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?

  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

// =====================================================================
// LeaveRequest (HR)
// =====================================================================

enum LeaveType {
  ANNUAL
  SICK
  PERSONAL
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id          String      @id @default(cuid())
  requesterId String      @map("requester_id")
  approverId  String?     @map("approver_id")
  type        LeaveType
  status      LeaveStatus @default(PENDING)
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  reason      String?

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  requester User  @relation("LeaveRequester", fields: [requesterId], references: [id])
  approver  User? @relation("LeaveApprover", fields: [approverId], references: [id])

  @@index([requesterId, status])
  @@index([approverId])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

// =====================================================================
// NotionConnection (Notion integration)
// =====================================================================

model NotionConnection {
  id            String   @id @default(cuid())
  workspaceId   String   @unique @map("workspace_id")
  accessToken   String   @map("access_token")
  botId         String   @map("bot_id")
  workspaceName String   @map("workspace_name")
  createdById   String   @map("created_by_id")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  createdBy User @relation("NotionConnections", fields: [createdById], references: [id])

  @@index([createdById])
  @@map("notion_connections")
}

// =====================================================================
// Approval / Client / Event / Resource (T1: in-memory → Prisma)
// =====================================================================

enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
}

model Approval {
  id          String         @id @default(cuid())
  title       String
  requesterId String         @map("requester_id")
  approverId  String         @map("approver_id")
  status      ApprovalStatus @default(pending)
  amount      Float?
  reason      String?
  decidedAt   DateTime?      @map("decided_at")

  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([approverId, status])
  @@index([requesterId])
  @@map("approvals")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  contact   String?
  email     String?
  phone     String?
  industry  String?
  ownerId   String?   @map("owner_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([ownerId])
  @@index([deletedAt])
  @@map("clients")
}

enum EventSource {
  internal
  google
  outlook
}

model Event {
  id         String      @id @default(cuid())
  title      String
  start      DateTime
  end        DateTime
  location   String?
  attendees  String[]    @default([])
  resourceId String?     @map("resource_id")
  source     EventSource @default(internal)
  createdById String?    @map("created_by_id")

  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([start])
  @@index([resourceId])
  @@map("events")
}

enum ResourceKind {
  room
  equipment
}

model Resource {
  id        String       @id
  name      String
  kind      ResourceKind
  capacity  Int?
  location  String?

  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  bookings  Booking[]

  @@map("resources")
}

model Booking {
  id         String   @id @default(cuid())
  resourceId String   @map("resource_id")
  start      DateTime
  end        DateTime
  bookedBy   String   @map("booked_by")

  createdAt  DateTime @default(now()) @map("created_at")

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, start])
  @@map("bookings")
}

// =====================================================================
// AI Thread / Message / Attachment / MCP Connection
// =====================================================================

enum AiMessageRole {
  user
  assistant
  tool
}

model AiThread {
  id        String      @id @default(cuid())
  title     String
  userId    String      @map("user_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  messages  AiMessage[]

  @@index([userId])
  @@index([deletedAt])
  @@map("ai_threads")
}

model AiMessage {
  id         String        @id @default(cuid())
  threadId   String        @map("thread_id")
  role       AiMessageRole
  content    String
  toolCalls  Json?         @map("tool_calls")
  citations  Json?
  model      String?
  usage      Json?
  createdAt  DateTime      @default(now()) @map("created_at")

  thread      AiThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments AiAttachment[]

  @@index([threadId, createdAt])
  @@map("ai_messages")
}

model AiAttachment {
  id         String    @id @default(cuid())
  messageId  String    @map("message_id")
  filename   String
  mimeType   String    @map("mime_type")
  sizeBytes  Int       @map("size_bytes")
  storageKey String    @map("storage_key")
  createdAt  DateTime  @default(now()) @map("created_at")

  message    AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("ai_attachments")
}

model McpConnection {
  id        String   @id @default(cuid())
  name      String   @unique
  transport String
  config    Json
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("mcp_connections")
}

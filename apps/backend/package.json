{
  "name": "@all-flow/backend",
  "version": "0.1.0",
  "private": true,
  "description": "ALL-Flow backend — Fastify 5 + Prisma 6 + Postgres 16 + Redis 7. Mirrors all-flow-frontend openapi.yaml.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "main": "dist/server.js",
  "module": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.seed.json && tsc -p tsconfig.tests.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "openapi:gen": "node scripts/openapi-to-zod.mjs",
    "openapi:check": "node scripts/openapi-drift.mjs",
    "openapi:contract": "node scripts/openapi-contract-check.mjs",
    "openapi:contract:strict": "node scripts/openapi-contract-check.mjs --strict",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^6.19.3",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "jose": "^5.10.0",
    "pgvector": "^0.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "prisma": "^6.19.3",
    "testcontainers": "^11.14.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "yaml": "^2.8.3"
  }
}

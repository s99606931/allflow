# ALL-Flow Backend 환경 변수 예시
# 실제 값은 .env (gitignore) 또는 비밀 관리 도구에 보관한다.

# 부트 (T-003)
NODE_ENV=development          # development | test | production
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=debug               # fatal | error | warn | info | debug | trace | silent

# DB / 캐시 (T-101 / T-004)
# DATABASE_URL=<postgres connection string>
# REDIS_URL=<redis connection string>

# docker-compose 호스트 포트 매핑 (T-004) — 기본값 충돌 시 변경
# POSTGRES_USER=allflow
# POSTGRES_PASSWORD=<change me>
# POSTGRES_DB=allflow
# POSTGRES_PORT=5432
# REDIS_PORT=6379

# 인증 (T-103)
# AUTH_SECRET=<32+ chars>

# AI (T-401)
# OPENAI_API_KEY=

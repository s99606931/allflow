{
  "name": "all-flow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "openapi:check": "npx -y @redocly/cli@latest lint openapi.yaml",
    "openapi:gen": "npx -y openapi-typescript@latest openapi.yaml -o src/lib/api-types.gen.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:cov": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "test:all": "pnpm test && pnpm e2e",
    "test:a11y": "playwright test tests/a11y",
    "screenshot:list": "tsx scripts/screenshot-diff.ts"
  },
  "dependencies": {
    "@auth/core": "^0.40.0",
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-pdf/renderer": "^4.3.0",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ky": "^1.7.5",
    "lucide-react": "^0.475.0",
    "motion": "^12.10.0",
    "next": "16.2.0",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.65.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.1",
    "zod": "^4.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.50.0",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/nextjs": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.20.1",
    "eslint-config-next": "16.2.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
}

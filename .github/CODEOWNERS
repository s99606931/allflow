# Owner mapping per OSS track. Update GitHub usernames before going public.
# Format: pattern  @owner1 @owner2

# Default — all changes
*                                    @autovibe-maintainers

# Dev track
/.editorconfig                       @autovibe-dev-leads
/.devcontainer/                      @autovibe-dev-leads

# Test track
/.github/workflows/ci.yml            @autovibe-test-leads
/.github/workflows/security.yml      @autovibe-security-leads
/tests/                              @autovibe-test-leads

# Docs track
/README.md                           @autovibe-docs-leads
/CHANGELOG.md                        @autovibe-docs-leads
/CONTRIBUTING.md                     @autovibe-docs-leads
/docs/                               @autovibe-docs-leads
/.github/ISSUE_TEMPLATE/             @autovibe-docs-leads
/.github/PULL_REQUEST_TEMPLATE.md    @autovibe-docs-leads

# Security track
/SECURITY.md                         @autovibe-security-leads
/.github/dependabot.yml              @autovibe-security-leads
/.githooks/                          @autovibe-security-leads
/.claude/hooks/av-oss-*.sh           @autovibe-security-leads

# Release track
/.github/workflows/release.yml       @autovibe-release-leads
/VERSION                             @autovibe-release-leads

# AV ecosystem (meta) — all maintainers (default)

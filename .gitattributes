# Owner: av-oss-dev-lead
# Normalize line endings + mark generated/binary content

* text=auto eol=lf

# Shell scripts must always be LF
*.sh        text eol=lf

# Windows-specific files keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Markdown / docs
*.md        text diff=markdown
*.json      text
*.yml       text
*.yaml      text
*.toml      text

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary

# Lock files — auto-generated, no diff churn
package-lock.json   linguist-generated=true
pnpm-lock.yaml      linguist-generated=true
yarn.lock           linguist-generated=true
Cargo.lock          linguist-generated=true
go.sum              linguist-generated=true
